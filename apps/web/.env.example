# ZimStable Integration Configuration
# Copy this to .env.local and fill in your credentials

# ============================================
# PAYNOW INTEGRATION (Zimbabwe Fiat On-Ramp)
# ============================================
# Paynow API Credentials
PAYNOW_INTEGRATION_KEY=your_paynow_integration_key_here
PAYNOW_API_URL=https://www.paynow.co.zw/api/initiate
PAYNOW_STATUS_URL=https://www.paynow.co.zw/api/status

# ============================================
# YELLOW CARD API (Liquidity Provider)
# ============================================
# Yellow Card API Credentials
YELLOWCARD_API_KEY=your_yellowcard_api_key_here
YELLOWCARD_API_URL=https://api.yellowcard.io/v2

# ============================================
# HOSTING AFRICA (Data Sovereignty)
# ============================================
# Hosting Africa API Credentials
HOSTING_AFRICA_API_KEY=your_hosting_africa_api_key_here
HOSTING_AFRICA_API_URL=https://api.hostingafrica.com/v1
HOSTING_AFRICA_REGION=zim

# ============================================
# CELO NETWORK CONFIGURATION
# ============================================
NEXT_PUBLIC_CELO_RPC_URL=https://alfajores-forno.celo-testnet.org
NEXT_PUBLIC_CELO_NETWORK=celo-sepolia

# ============================================
# APPLICATION CONFIG
# ============================================
NEXT_PUBLIC_APP_URL=https://vm952cali.yourlocaldomain.com
NEXT_PUBLIC_APP_ENVIRONMENT=production
